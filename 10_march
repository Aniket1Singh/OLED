// =============================================================================
// Draw helpers
// =============================================================================
void drawBigDigit(int x, int y, int digit)
{
  for (int row = 0; row < BIG_HEIGHT; row++) {
    for (int b = 0; b < 3; b++) {
      uint8_t data = pgm_read_byte(&BigDigits[digit][row][b]);
      for (int bit = 0; bit < 8; bit++) {
        if (data & (1 << (7 - bit))) {
          int col = b * 8 + bit;
          if (col < BIG_WIDTH)
            u8g2.drawPixel(x + col, y + row);
        }
      }
    }
  }
}

void drawSmlSymbol(int x, int y, int idx)
{
  for (int row = 0; row < SML_HEIGHT; row++) {
    for (int b = 0; b < 2; b++) {
      uint8_t data = pgm_read_byte(&SmlSymbols[idx][row][b]);
      for (int bit = 0; bit < 8; bit++) {
        if (data & (1 << (7 - bit))) {
          int col = b * 8 + bit;
          if (col < SML_WIDTH)
            u8g2.drawPixel(x + col, y + row);
        }
      }
    }
  }
}

void drawNewGlyph(int x, int y, int idx)
{
  for (int row = 0; row < NEW_HEIGHT; row++) {
    for (int b = 0; b < 4; b++) {
      uint8_t data = pgm_read_byte(&NewGlyph[idx][row][b]);
      for (int bit = 0; bit < 8; bit++) {
        if (data & (1 << (7 - bit))) {
          int col = b * 8 + bit;
          if (col < NEW_WIDTH)
            u8g2.drawPixel(x + col, y + row);
        }
      }
    }
  }
}

// Draw one tiny char at pixel position (x, y)
void drawTinyChar(int x, int y, const uint8_t* charData)
{
  for (int row = 0; row < TINY_H; row++) {
    uint8_t data = pgm_read_byte(charData + row);
    for (int bit = 0; bit < TINY_W; bit++) {
      if (data & (1 << (7 - bit)))
        u8g2.drawPixel(x + bit, y + row);
    }
  }
}

// Draw ALL tiny chars as a font sheet on screen together
// Layout: 13 chars per row, 9px spacing (8px char + 1px gap)
// Row spacing: 13px (11px char + 2px gap)
// Page 0: A-Z + 0-9 + ?  (37 chars)
// Page 1: : -> / ! . ,   (6 symbols)
void drawTinyFontSheet(bool showSymbols)
{
  const int COLS    = 13;   // chars per row
  const int CHAR_W  = 9;    // 8px + 1 gap
  const int CHAR_H  = 13;   // 11px + 2 gap
  const int START_X = 1;
  const int START_Y = 4;

  if (!showSymbols) {
    // Show A-Z, 0-9, ? — all 37 chars in a grid
    for (int i = 0; i < TINY_COUNT; i++) {
      int col = i % COLS;
      int row = i / COLS;
      drawTinyChar(START_X + col * CHAR_W, START_Y + row * CHAR_H, TinyFont[i]);
    }
  } else {
    // Show : -> / ! . ,  — 6 extra symbols
    for (int i = 0; i < TINY_EXTRA_COUNT; i++) {
      int col = i % COLS;
      int row = i / COLS;
      drawTinyChar(START_X + col * CHAR_W, START_Y + row * CHAR_H, TinyExtra[i]);
    }
  }
}


// =============================================================================
// Cycle order:
//   0–9   → big digits 0-9
//   10–15 → small symbols (L, O, V, %, BigStar, MedStar)
//   16–18 → new 4-byte glyphs (signal, battery, icon3)
//   19    → tiny font sheet page 1 (A-Z, 0-9, ?)
//   20    → tiny font sheet page 2 (:, ->, /, !, ., ,)
// =============================================================================
#undef  GLYPH_COUNT
#define GLYPH_COUNT 21   // 10 + 6 + 3 + 2 tiny pages

int currentGlyph = 0;

void setup()
{
  u8g2.setI2CAddress(0x3D << 1);
  u8g2.begin();
}

void loop()
{
  u8g2.firstPage();
  do {
    if (currentGlyph < BIG_COUNT) {
      drawBigDigit(54, 42, currentGlyph);

    } else if (currentGlyph < BIG_COUNT + SML_COUNT) {
      drawSmlSymbol(56, 58, currentGlyph - BIG_COUNT);

    } else if (currentGlyph < BIG_COUNT + SML_COUNT + NEW_COUNT) {
      drawNewGlyph(48, 51, currentGlyph - BIG_COUNT - SML_COUNT);

    } else if (currentGlyph == BIG_COUNT + SML_COUNT + NEW_COUNT) {
      drawTinyFontSheet(false);   // A-Z, 0-9, ?

    } else {
      drawTinyFontSheet(true);    // :  ->  /  !  .  ,
    }
  } while (u8g2.nextPage());

  delay(1000);

  currentGlyph = (currentGlyph + 1) % GLYPH_COUNT;
}
