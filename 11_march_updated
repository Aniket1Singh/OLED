// =============================================================================
// Draw helpers — use drawXBMP (block XBM from PROGMEM) instead of per-pixel
// drawXBMP sends whole rows as bytes directly into U8g2 buffer — ~20-50x
// faster than calling drawPixel() for every single bit.
//
// IMPORTANT: XBM format is LSB-first per byte (bit0 = leftmost pixel).
// Our bitmaps are MSB-first, so we use a fast byte-reverse per row.
// =============================================================================

// Reverse bits in a byte: MSB-first → LSB-first for XBM
static inline uint8_t reverseByte(uint8_t b) {
  b = (b & 0xF0) >> 4 | (b & 0x0F) << 4;
  b = (b & 0xCC) >> 2 | (b & 0x33) << 2;
  b = (b & 0xAA) >> 1 | (b & 0x55) << 1;
  return b;
}

// Scratch row buffer — large enough for widest glyph (NEW_WIDTH=32 → 4 bytes)
// Lives in RAM but is tiny (4 bytes) and reused every row
static uint8_t rowBuf[4];

void drawBigDigit(int x, int y, int digit)
{
  // BIG: 20px wide → 3 bytes/row (24 bits, rightmost 4 bits unused)
  for (int row = 0; row < BIG_HEIGHT; row++) {
    rowBuf[0] = reverseByte(pgm_read_byte(&BigDigits[digit][row][0]));
    rowBuf[1] = reverseByte(pgm_read_byte(&BigDigits[digit][row][1]));
    rowBuf[2] = reverseByte(pgm_read_byte(&BigDigits[digit][row][2]));
    u8g2.drawXBM(x, y + row, BIG_WIDTH, 1, rowBuf);
  }
}

void drawSmlSymbol(int x, int y, int idx)
{
  // SML: 16px wide → 2 bytes/row
  for (int row = 0; row < SML_HEIGHT; row++) {
    rowBuf[0] = reverseByte(pgm_read_byte(&SmlSymbols[idx][row][0]));
    rowBuf[1] = reverseByte(pgm_read_byte(&SmlSymbols[idx][row][1]));
    u8g2.drawXBM(x, y + row, SML_WIDTH, 1, rowBuf);
  }
}

void drawNewGlyph(int x, int y, int idx)
{
  // NEW: 32px wide → 4 bytes/row
  for (int row = 0; row < NEW_HEIGHT; row++) {
    rowBuf[0] = reverseByte(pgm_read_byte(&NewGlyph[idx][row][0]));
    rowBuf[1] = reverseByte(pgm_read_byte(&NewGlyph[idx][row][1]));
    rowBuf[2] = reverseByte(pgm_read_byte(&NewGlyph[idx][row][2]));
    rowBuf[3] = reverseByte(pgm_read_byte(&NewGlyph[idx][row][3]));
    u8g2.drawXBM(x, y + row, NEW_WIDTH, 1, rowBuf);
  }
}

void drawTinyChar(int x, int y, const uint8_t* charData)
{
  // TINY: 8px wide → 1 byte/row
  for (int row = 0; row < TINY_H; row++) {
    rowBuf[0] = reverseByte(pgm_read_byte(charData + row));
    u8g2.drawXBM(x, y + row, TINY_W, 1, rowBuf);
  }
}

void drawTinyFontSheet(bool showSymbols)
{
  const int COLS    = 13;
  const int CHAR_W  =  9;
  const int CHAR_H  = 13;
  const int START_X =  1;
  const int START_Y =  4;

  if (!showSymbols) {
    for (int i = 0; i < TINY_COUNT; i++)
      drawTinyChar(START_X + (i % COLS) * CHAR_W,
                   START_Y + (i / COLS) * CHAR_H,
                   TinyFont[i]);
  } else {
    for (int i = 0; i < TINY_EXTRA_COUNT; i++)
      drawTinyChar(START_X + (i % COLS) * CHAR_W,
                   START_Y + (i / COLS) * CHAR_H,
                   TinyExtra[i]);
  }
}

// Central draw dispatcher — call inside firstPage/nextPage loop
void drawCurrentGlyph(int g)
{
  if (g < BIG_COUNT) {
    drawBigDigit(54, 42, g);

  } else if (g < BIG_COUNT + SML_COUNT) {
    drawSmlSymbol(56, 58, g - BIG_COUNT);

  } else if (g < BIG_COUNT + SML_COUNT + NEW_COUNT) {
    drawNewGlyph(48, 51, g - BIG_COUNT - SML_COUNT);

  } else if (g == BIG_COUNT + SML_COUNT + NEW_COUNT) {
    drawTinyFontSheet(false);   // A-Z, 0-9, ?, bar

  } else {
    drawTinyFontSheet(true);    // :  ->  /  !  .  ,
  }
}


// =============================================================================
// Setup & Loop
// =============================================================================
int      currentGlyph = 0;
uint32_t lastSwitch   = 0;      // millis() timestamp of last glyph change

void setup()
{
  // ── Run CPU at full 16 MHz — NO prescaler ────────────────────────────────
  // Dividing clock (e.g. /4 = 4MHz or /16 = 1MHz) makes everything SLOWER:
  // pixel drawing loops, pgm_read_byte, I2C bit-banging — all get slower.
  // ATtiny was fast because it ran at 8/16MHz natively. Match that here.
  cli();
  CLKPR = 0x80;   // unlock CLKPR
  CLKPR = 0x00;   // prescaler = /1 → full 16 MHz
  sei();

  // ── I2C at 400 kHz (Fast Mode) — max speed at 16 MHz ────────────────────
  // TWBR formula: ((F_CPU / SCL_freq) - 16) / 2
  // At 16 MHz, 400 kHz: TWBR = ((16000000/400000) - 16) / 2 = 12
  Wire.begin();
  TWSR = 0x00;    // TWI prescaler = 1
  TWBR = 12;      // → exactly 400 kHz I2C at 16 MHz CPU

  u8g2.setI2CAddress(0x3D << 1);
  u8g2.begin();
  u8g2.setDrawColor(1);
}

void loop()
{
  // ── Render current glyph as fast as possible (no blocking inside) ─────────
  // Page mode: 16 pages × ~1.6 ms @ 400 kHz I2C = ~25 ms full frame @ 16 MHz
  u8g2.firstPage();
  do {
    drawCurrentGlyph(currentGlyph);
  } while (u8g2.nextPage());

  // ── Non-blocking 1-second hold using millis() ─────────────────────────────
  // Unlike delay(), millis() doesn't block — the render loop keeps running
  // at full speed. The glyph simply doesn't change until 1000 ms has elapsed.
  uint32_t now = millis();
  if (now - lastSwitch >= (uint32_t)DISPLAY_MS) {
    lastSwitch   = now;
    currentGlyph = (currentGlyph + 1) % GLYPH_COUNT;
  }
}
