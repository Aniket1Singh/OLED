static uint8_t rowBuf[3];
static inline uint8_t rev(uint8_t b) {
  b = (b & 0xF0) >> 4 | (b & 0x0F) << 4;
  b = (b & 0xCC) >> 2 | (b & 0x33) << 2;
  b = (b & 0xAA) >> 1 | (b & 0x55) << 1;
  return b;
}

void drawBigDigit(int x, int y, int d) {
  for (int row = 0; row < BIG_H; row++) {
    rowBuf[0] = rev(pgm_read_byte(&BigDigits[d][row][0]));
    rowBuf[1] = rev(pgm_read_byte(&BigDigits[d][row][1]));
    rowBuf[2] = rev(pgm_read_byte(&BigDigits[d][row][2]));
    u8g2.drawXBM(x, y + row, BIG_W, 1, rowBuf);
  }
}

// ── Callback that forces TWBR after every U8g2 I2C transaction ───────────
extern "C" uint8_t u8x8_byte_arduino_hw_i2c(u8x8_t*, uint8_t, uint8_t, void*);
uint8_t my_i2c_cb(u8x8_t *u8x8, uint8_t msg, uint8_t arg_int, void *arg_ptr) {
  uint8_t r = u8x8_byte_arduino_hw_i2c(u8x8, msg, arg_int, arg_ptr);
  TWSR = 0x00;
  TWBR = FAST_TWBR;
  return r;
}

int cur = 0;

void setup() {
  Serial.begin(115200);
  while (!Serial);

  u8g2.setI2CAddress(0x3D << 1);
  u8g2.begin();
  u8g2.getU8x8()->byte_cb = my_i2c_cb;   // hook our fast callback
  TWSR = 0x00;
  TWBR = FAST_TWBR;
  u8g2.setDrawColor(1);

  uint32_t khz = (uint32_t)F_CPU / (16UL + 2UL*(uint32_t)FAST_TWBR) / 1000UL;
  Serial.print(F("TWBR=")); Serial.print(FAST_TWBR);
  Serial.print(F("  I2C_kHz=")); Serial.println(khz);
  Serial.println(F("If display looks corrupted, increase TWBR (try 12->6->3->1->0)"));
}

void loop() {
  uint32_t t0 = micros();
  u8g2.firstPage();
  do {
    drawBigDigit(54, 42, cur);
  } while (u8g2.nextPage());
  uint32_t t1 = micros();

  uint32_t frame_ms = (t1 - t0) / 1000UL;
  Serial.print(F("digit=")); Serial.print(cur);
  Serial.print(F("  frame_ms=")); Serial.print(frame_ms);
  Serial.print(F("  fps~")); Serial.println(1000UL / (frame_ms ? frame_ms : 1));

  cur = (cur + 1) % BIG_N;
  // no delay — swap as fast as hardware allows
}
