#include <U8g2lib.h>
#include <Wire.h>
#include <avr/pgmspace.h>

U8G2_SSD1327_WS_128X128_2_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE);

#define BIG_W  20
#define BIG_H  43
#define BIG_N   2

// ── Try these one at a time, lowest = fastest ─────────────────────────────
// TWBR=12 → 400 kHz → 514 ms/frame  (confirmed working)
// TWBR=6  → 571 kHz → ~130 ms/frame
// TWBR=3  → 727 kHz → ~100 ms/frame
// TWBR=2  → 800 kHz → ~92  ms/frame
// TWBR=1  → 889 kHz → ~83  ms/frame
// TWBR=0  → 1000 kHz → ~74 ms/frame  (may corrupt display if wires too long)
// Start with 6, if display still works try 3, then 1, then 0
#define FAST_TWBR  3

