void drawChar(int x,int y,const uint8_t *bitmap)
{
  for(int row=0; row<CHAR_HEIGHT; row++)
  {
    uint8_t rowData = bitmap[row];

    for(int col=0; col<CHAR_WIDTH; col++)
    {
      if(rowData & (1 << (7-col)))
      {
        u8g2.drawPixel(x+col,y+row);
      }
    }
  }
}

void setup()
{
  u8g2.setI2CAddress(0x3D << 1);
  u8g2.begin();
}

void loop()
{
  u8g2.firstPage();
  do {

    int x=0;
    int y=10;

    for(int i=0;i<CHAR_COUNT;i++)
    {
      drawChar(x,y,font[i]);

      x += 10;

      if(x > 120)
      {
        x = 0;
        y += 14;
      }
    }
    

  } while (u8g2.nextPage());
}
