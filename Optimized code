// =============================================================================
// Draw functions
// =============================================================================

// Draw a big digit using RLE-compressed data
void drawBigDigit(int x, int y, int digit) {
  const uint8_t* ptr = (const uint8_t*)pgm_read_ptr(&BigDigitPtrs[digit]);
  int row = 0;
  while (row < BIG_HEIGHT) {
    uint8_t count = pgm_read_byte(ptr++);
    if (count == 0x00) break;                          // end of glyph
    uint8_t b0 = pgm_read_byte(ptr++);
    uint8_t b1 = pgm_read_byte(ptr++);
    uint8_t b2 = pgm_read_byte(ptr++);
    for (uint8_t r = 0; r < count && row < BIG_HEIGHT; r++, row++) {
      uint8_t bytes[3] = {b0, b1, b2};
      for (int b = 0; b < 3; b++) {
        for (int bit = 7; bit >= 0; bit--) {
          int col = b * 8 + (7 - bit);
          if (col < BIG_WIDTH && (bytes[b] & (1 << bit)))
            u8g2.drawPixel(x + col, y + row);
        }
      }
    }
  }
}

// Draw a small symbol (raw)
void drawSmlSymbol(int x, int y, int idx) {
  for (int row = 0; row < SML_HEIGHT; row++) {
    for (int b = 0; b < 2; b++) {
      uint8_t data = pgm_read_byte(&SmlSymbols[idx][row][b]);
      for (int bit = 7; bit >= 0; bit--) {
        int col = b * 8 + (7 - bit);
        if (col < SML_WIDTH && (data & (1 << bit)))
          u8g2.drawPixel(x + col, y + row);
      }
    }
  }
}

// Draw a new 32-bit-wide glyph (raw)
void drawNewGlyph(int x, int y, int idx) {
  for (int row = 0; row < NEW_HEIGHT; row++) {
    for (int b = 0; b < 4; b++) {
      uint8_t data = pgm_read_byte(&NewGlyph[idx][row][b]);
      for (int bit = 7; bit >= 0; bit--) {
        int col = b * 8 + (7 - bit);
        if (col < NEW_WIDTH && (data & (1 << bit)))
          u8g2.drawPixel(x + col, y + row);
      }
    }
  }
}

// Draw one tiny character at (x, y) using a PROGMEM pointer
void drawTinyChar(int x, int y, const uint8_t* ptr) {
  for (int row = 0; row < TINY_H; row++) {
    uint8_t data = pgm_read_byte(ptr + row);
    for (int bit = 7; bit >= 0; bit--)
      if (data & (1 << bit))
        u8g2.drawPixel(x + (7 - bit), y + row);
  }
}

// Draw all tiny chars as a grid sheet
// showSymbols=false → A-Z, 0-9, ?   showSymbols=true → : -> / ! . ,
void drawTinyFontSheet(bool showSymbols) {
  const int cols   = 13;
  const int xStep  = 9;
  const int yStep  = 13;
  const int startX = 2;
  const int startY = 4;
  int count = showSymbols ? TINY_EXTRA_COUNT : TINY_COUNT;
  for (int i = 0; i < count; i++) {
    int cx = startX + (i % cols) * xStep;
    int cy = startY + (i / cols) * yStep;
    const uint8_t* ptr = showSymbols
      ? (const uint8_t*)TinyExtra[i]
      : (const uint8_t*)TinyFont[i];
    drawTinyChar(cx, cy, ptr);
  }
}

// =============================================================================
// Main loop — cycle through all 21 glyphs, 1 second each
// =============================================================================
int currentGlyph = 0;

void setup() {
  u8g2.setI2CAddress(0x3D << 1);
  u8g2.begin();
}

void loop() {
  u8g2.firstPage();
  do {
    if (currentGlyph < BIG_COUNT) {
      drawBigDigit(54, 42, currentGlyph);

    } else if (currentGlyph < BIG_COUNT + SML_COUNT) {
      drawSmlSymbol(56, 58, currentGlyph - BIG_COUNT);

    } else if (currentGlyph < BIG_COUNT + SML_COUNT + NEW_COUNT) {
      drawNewGlyph(48, 51, currentGlyph - BIG_COUNT - SML_COUNT);

    } else if (currentGlyph == BIG_COUNT + SML_COUNT + NEW_COUNT) {
      drawTinyFontSheet(false);   // A-Z, 0-9, ?

    } else {
      drawTinyFontSheet(true);    // :  ->  /  !  .  ,
    }
  } while (u8g2.nextPage());

  delay(1000);
  currentGlyph = (currentGlyph + 1) % GLYPH_COUNT;
}
